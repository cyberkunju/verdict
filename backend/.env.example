# VERDICT backend environment template
# Copy to backend/.env and fill values. .env is gitignored.

# --- LLM ---
OPENAI_API_KEY=sk-replace-with-your-key
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2

# --- Whisper ---
# Options: tiny, base, small, medium, large-v3. small is the sweet spot for hackathon.
WHISPER_MODEL=small
WHISPER_DEVICE=auto              # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=auto        # auto | int8 | float16 | float32

# --- rPPG ---
RPPG_FPS=30                      # target sample rate after resample
RPPG_LOW_HZ=0.7                  # ~42 bpm
RPPG_HIGH_HZ=3.0                 # ~180 bpm
RPPG_WINDOW_SECONDS=10           # sliding window for HR estimation

# --- Pipeline ---
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SCHEMA_VERSION=1.0

# --- Modal (VerdictTextPrior-v1 inference) ---
# Set these OR run: modal token set --token-id <id> --token-secret <secret>
# which writes to ~/.modal.toml (preferred for local dev)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
